import matplotlib.pyplot as plt
import numpy as np

# ---- Input Section ----
TP = int(input("Enter True Positives (TP): "))
TN = int(input("Enter True Negatives (TN): "))
FP = int(input("Enter False Positives (FP): "))

FN = int(input("Enter False Negatives (FN): "))

# ---- Total ----
total = TP + TN + FP + FN

# ---- Metrics Calculation ----
accuracy = (TP + TN) / total
precision = TP / (TP + FP) if (TP + FP) != 0 else 0
recall = TP / (TP + FN) if (TP + FN) != 0 else 0
specificity = TN / (TN + FP) if (TN + FP) != 0 else 0
f1 = (2 * precision * recall) / (precision + recall) if (precision + recall) != 0 else 0

# ---- Print Results ----
print("\n---- Evaluation Metrics ----")
print("Accuracy    :", round(accuracy, 4))
print("Precision   :", round(precision, 4))
print("Recall      :", round(recall, 4))
print("Specificity :", round(specificity, 4))
print("F1 Score    :", round(f1, 4))
print(f"1?? Accuracy = {accuracy:.3f}")
print("   Meaning: Overall correctness of the model.")
print("   It tells what percentage of total predictions are correct.\n")

print(f"2?? Precision = {precision:.3f}")
print("   Meaning: Out of all predicted Positive cases, how many were actually Positive?")
print("   Important when False Positives are costly (e.g., spam detection).\n")

print(f"3?? Recall (Sensitivity) = {recall:.3f}")
print("   Meaning: Out of all Actual Positive cases, how many did the model correctly detect?")
print("   Important in medical diagnosis where missing a positive case is risky.\n")

print(f"4?? Specificity = {specificity:.3f}")
print("   Meaning: Out of all Actual Negative cases, how many did the model correctly identify?")
print("   Measures how well the model avoids False Alarms.\n")

print(f"5?? F1 Score = {f1:.3f}")
print("   Meaning: Harmonic mean of Precision and Recall.")
print("   Useful when you want balance between Precision and Recall.\n")

# ---- Confusion Matrix ----
cm = np.array([[TP, FN],
               [FP, TN]])

# ---- Plot ----
plt.figure()
plt.imshow(cm)
plt.title("Confusion Matrix")
plt.xticks([0,1], ["Predicted Positive", "Predicted Negative"])
plt.yticks([0,1], ["Actual Positive", "Actual Negative"])

# Add text inside each cell
labels = [["TP", "FN"],
          ["FP", "TN"]]

for i in range(2):
    for j in range(2):
        plt.text(j, i, labels[i][j] + "\n" + str(cm[i][j]),
                 ha='center', va='center')

plt.xlabel("Predicted Label")
plt.ylabel("Actual Label")

plt.colorbar()
plt.show()